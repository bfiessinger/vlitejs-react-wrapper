{
  "name": "@bfiessinger/vlitejs-react-wrapper",
  "version": "1.0.0",
  "description": "A React wrapper component for the vlitejs video/audio player",
  "main": "dist/vlitejs-react-wrapper.cjs",
  "module": "dist/vlitejs-react-wrapper.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/vlitejs-react-wrapper.mjs",
      "require": "./dist/vlitejs-react-wrapper.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bfiessinger/vlitejs-react-wrapper.git"
  },
  "keywords": [
    "react",
    "vlitejs",
    "video",
    "audio",
    "player",
    "wrapper"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/bfiessinger/vlitejs-react-wrapper/issues"
  },
  "homepage": "https://github.com/bfiessinger/vlitejs-react-wrapper#readme",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "react": "*",
    "react-dom": "*",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18",
    "vlitejs": "^8.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "vlitejs": "^8.0.0"
  }
}
